{
  "expo": {
    "name": "NaaApp",
    "slug": "mynaaapp-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/naal.png",
    "scheme": "mynaaapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.NaaApp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "We need access to Face ID to secure your account and allow quick sign-in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/naal.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.NaaApp",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/naal.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/naal.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "SUPABASE_URL": "$EXPO_PUBLIC_SUPABASE_URL",
      "SUPABASE_ANON_KEY": "$EXPO_PUBLIC_SUPABASE_ANON_KEY",
      "SUPABASE_SERVICE_ROLE_KEY": "$EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7c19c24e-d837-473e-a6c7-b5a3458902d5"
      }
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/7c19c24e-d837-473e-a6c7-b5a3458902d5"
    },
    "runtimeVersion": "1.0.0"
  }
}
