# Required Configuration
EXPO_PUBLIC_PLATFORM=com.NaaApp

# Supabase Configuration (Primary Backend)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# WARNING: Service role key should only be used server-side, not in client apps
# EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google OAuth Configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id

# OneSignal Configuration (Push Notifications)
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
EXPO_PUBLIC_ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
EXPO_PUBLIC_ONESIGNAL_CHANNEL_ID=your-onesignal-channel-id

# OCR Configuration (Receipt Scanning)
EXPO_PUBLIC_OCR_API_KEY=your-ocr-space-api-key
EXPO_PUBLIC_OCR_API_ENDPOINT=https://api.ocr.space/parse/image

# AI Configuration (Optional - for AI image generation)
EXPO_PUBLIC_AI_KEY=your-hugging-face-api-key
EXPO_PUBLIC_AI_IMAGE_ENDPOINT=https://api-inference.huggingface.co/models/your-model

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit .env to version control
# 4. All variables must start with EXPO_PUBLIC_ to be accessible in the app

